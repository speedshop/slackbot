# Slack App Credentials
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-token
SLACK_ADMIN_USER_ID=U0123456789

# GitHub Configuration
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_ORG=The-Complete-Guide-To-Rails-Performance
GITHUB_TEAM_ID=1958350

# Cloudflare R2 Configuration
# One credential pair is used for both archive URL signing and marker writes.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Monthly archive ZIP (read for bot, write for your upload script)
R2_BUCKET=railsperf-exports
R2_OBJECT_KEY=railsperf-export-latest.zip

# Processed-user markers (separate bucket managed by Terraform in this repo)
R2_MARKERS_BUCKET=railsperf-processed-users

R2_REGION=auto

NODE_ENV=development
LOG_LEVEL=info
