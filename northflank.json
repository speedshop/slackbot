{
  "apiVersion": "v1.2",
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "context": {
        "projectId": "cgrp-slackbot"
      },
      "steps": [
        {
          "kind": "SecretGroup",
          "ref": "secrets",
          "spec": {
            "name": "slackbot-secrets",
            "secretType": "environment-arguments",
            "priority": 10,
            "secrets": {
              "variables": {
                "SLACK_BOT_TOKEN": "${args.SLACK_BOT_TOKEN}",
                "SLACK_SIGNING_SECRET": "${args.SLACK_SIGNING_SECRET}",
                "SLACK_APP_TOKEN": "${args.SLACK_APP_TOKEN}",
                "SLACK_ADMIN_USER_ID": "${args.SLACK_ADMIN_USER_ID}",
                "GITHUB_TOKEN": "${args.GITHUB_TOKEN}",
                "GITHUB_ORG": "${args.GITHUB_ORG}",
                "GITHUB_TEAM_ID": "${args.GITHUB_TEAM_ID}",
                "R2_ACCOUNT_ID": "${args.R2_ACCOUNT_ID}",
                "R2_ACCESS_KEY_ID": "${args.R2_ACCESS_KEY_ID}",
                "R2_SECRET_ACCESS_KEY": "${args.R2_SECRET_ACCESS_KEY}",
                "R2_BUCKET": "${args.R2_BUCKET}",
                "R2_OBJECT_KEY": "${args.R2_OBJECT_KEY}",
                "R2_MARKERS_BUCKET": "${args.R2_MARKERS_BUCKET}",
                "R2_REGION": "${args.R2_REGION}",
                "NODE_ENV": "production",
                "LOG_LEVEL": "info"
              }
            },
            "restrictions": {
              "restricted": false,
              "nfObjects": [],
              "tags": []
            }
          }
        },
        {
          "kind": "CombinedService",
          "ref": "slackbot",
          "spec": {
            "deployment": {
              "instances": 1,
              "storage": {
                "ephemeralStorage": {
                  "storageSize": 1024
                },
                "shmSize": 64
              },
              "docker": {
                "configType": "default"
              }
            },
            "loadBalancing": {
              "mode": "leastConnection"
            },
            "buildSettings": {
              "storage": {
                "ephemeralStorage": {
                  "storageSize": 16384
                }
              },
              "dockerfile": {
                "buildEngine": "kaniko",
                "dockerFilePath": "/Dockerfile",
                "dockerWorkDir": "/"
              }
            },
            "name": "slackbot",
            "billing": {
              "deploymentPlan": "nf-compute-10",
              "buildPlan": "nf-compute-400-16"
            },
            "vcsData": {
              "projectType": "github",
              "projectUrl": "${args.REPO_URL}",
              "projectBranch": "main"
            },
            "ports": [],
            "disabledCI": false,
            "buildConfiguration": {
              "pathIgnoreRules": [],
              "isAllowList": false,
              "ciIgnoreFlagsEnabled": false
            },
            "runtimeEnvironment": {},
            "buildArguments": {},
            "runtimeFiles": {},
            "buildFiles": {},
            "dockerSecretMounts": {},
            "infrastructure": {
              "architecture": "x86"
            }
          }
        }
      ]
    }
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "allow"
  },
  "gitops": {
    "repoUrl": "https://github.com/speedshop/slackbot",
    "vcsService": "github",
    "branch": "main",
    "filePath": "/northflank.json"
  },
  "$schema": "https://api.northflank.com/v1/schemas/template"
}